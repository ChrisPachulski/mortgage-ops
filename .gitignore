# Python
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
*.egg-info/
build/
dist/

# uv
.uv-cache/

# User Layer (DATA_CONTRACT.md) — NEVER commit
config/household.yml
config/profile.yml
modes/_profile.md

# Phase 10: skill user-layer override (DATA_CONTRACT.md User Layer)
.claude/skills/mortgage-ops/modes/_profile.md

# Data Layer (generated)
data/*.duckdb
data/market/
data/mortgage-ops.duckdb-wal
data/mortgage-ops.duckdb-shm

# Reports (generated)
reports/*
!reports/.gitkeep

# OS / editor
.DS_Store
.idea/
.vscode/

# macOS Finder drag-copy duplicates (e.g., "foo 2.py", ".lock 3"). These
# accidentally pollute pytest collection and break the test suite (Phase 17
# review). tests/test_repo_hygiene.py is the strict gate; these patterns
# are belt-and-suspenders. Force-add with `git add -f` if a real file
# legitimately needs this naming.
* [0-9].*
* [0-9][0-9].*
* copy.*
.lock [0-9]
.lock [0-9][0-9]

# Phase 9: Node orchestration artifacts
node_modules/
package-lock.json.bak

# Phase 9: DuckDB writer lockfile (ephemeral; per PATTERNS Critical Issue 1)
data/.lock

# Operational observability — per-run JSONL logs from CLI invocations.
# Logs are ephemeral artifacts; see docs/observability.md.
data/logs/

# Phase 9: Generated markdown views (regenerated from DuckDB; never hand-edited)
data/loans.md
data/scenarios.md

# Phase 9 (Plan 09-07): DuckDB writer lockfile defensive name (RESEARCH Pitfall 5)
# Production lockfile is the short name above; this entry catches any future
# rename to the longer per-DB convention without breaking Reference Layer commits.
data/.mortgage-ops.duckdb.lock

# Phase 12: FRED cache (Data Layer — generated, never committed)
data/cache/fred_*.json
data/cache/.fred-cache.lock

# Phase 13 — per-zpid HTML cache for --user-provided round-trips (Data Layer; generated)
data/cache/property-*.html
# Phase 13 Plan 13-04 — per-zpid extracted-dict JSON companion (Q1 default; skips re-Sonnet)
data/cache/property-*.json

# Phase 15 Plan 15-03 — sidecar listing JSON used for citation-footer
# reproducibility (Data Layer; generated by .claude/skills/mortgage-ops/scripts/property_analyze.py)
data/property-listings/

# Phase 12: eval runs (System Layer write target — generated)
evals/runs/*
!evals/runs/.gitkeep

# Codex perfection loop state (per-run scratch; never committed)
.codex-loop/
